@using Prospector.Web.Client.Components
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prospector - Análise de Prospectos</title>
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="Prospector.Web.styles.css" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <HeadOutlet />
</head>
<body>
    <div id="loading-screen" style="position:fixed;inset:0;background:#0D1117;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity 0.4s ease;animation:hideOverlay 0.4s ease 12s forwards;">
        <div style="font-size:1.75rem;font-weight:700;color:#4FC3F7;letter-spacing:4px;margin-bottom:1rem;">PROSPECTOR</div>
        <div style="color:rgba(230,237,243,0.45);font-size:0.875rem;margin-bottom:2rem;">Plataforma Analítica de Prospectos QB</div>
        <div style="width:48px;height:48px;border:3px solid rgba(79,195,247,0.2);border-top-color:#4FC3F7;border-radius:50%;animation:spin 0.8s linear infinite;"></div>
        <style>
            @@keyframes spin { to { transform: rotate(360deg) } }
            @@keyframes hideOverlay { to { opacity: 0; pointer-events: none; visibility: hidden; } }
        </style>
    </div>
    <Routes @rendermode="@(new InteractiveWebAssemblyRenderMode(prerender: false))" />
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script>
        var _blazorDismissed = false;
        function _dismissLoading() {
            if (_blazorDismissed) return;
            _blazorDismissed = true;
            var el = document.getElementById('loading-screen');
            if (el) { el.style.opacity = '0'; setTimeout(function () { el.remove(); }, 450); }
        }
        Blazor.start()
            .then(_dismissLoading)
            .catch(function (e) { console.error('[Prospector] Blazor.start() error:', e); _dismissLoading(); });
        setTimeout(_dismissLoading, 12000);
    </script>
</body>
</html>
