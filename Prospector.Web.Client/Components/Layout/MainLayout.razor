@inherits LayoutComponentBase
@inject NavigationManager Nav

<MudLayout>
    <MudAppBar Elevation="0" Dense="false" Style="border-bottom: 1px solid rgba(230,237,243,0.12);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="ml-2" Style="font-weight:700; letter-spacing:0.5px;">
            <span style="color:#4FC3F7;">PROSPECTOR</span>
        </MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-2 d-none d-sm-flex"
                         Style="color: rgba(230,237,243,0.65);">
                    @context.User.Identity?.Name
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               Title="Sair" OnClick="Logout" />
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/account/login" Variant="Variant.Text" Color="Color.Primary">Entrar</MudButton>
                <MudButton Href="/account/register" Variant="Variant.Filled" Color="Color.Primary" Class="ml-2">
                    Cadastrar
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
               Variant="DrawerVariant.Responsive"
               Style="border-right: 1px solid rgba(230,237,243,0.08);">
        <MudNavMenu Class="pt-4">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/players" Icon="@Icons.Material.Filled.People">
                Prospectos
            </MudNavLink>
            <MudNavLink Href="/compare" Icon="@Icons.Material.Filled.CompareArrows">
                Comparar
            </MudNavLink>
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.overline" Class="px-4 mb-1"
                     Style="color:rgba(230,237,243,0.35); font-size:0.62rem; letter-spacing:1.5px;">
                CLASSE DE DRAFT
            </MudText>
            <MudNavLink Href="/players?draftYear=2025" Icon="@Icons.Material.Filled.FilterList">
                Draft 2025
            </MudNavLink>
            <MudNavLink Href="/players?draftYear=2026" Icon="@Icons.Material.Filled.FilterList">
                Draft 2026
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void Logout() => Nav.NavigateTo("/account/logout-redirect", forceLoad: true);
}
