<div class="d-flex justify-space-between align-center py-2"
     style="border-bottom: 1px solid rgba(230,237,243,0.06);">
    <div>
        <MudText Typo="Typo.body2" Style="font-weight:500;">@Label</MudText>
        @if (!string.IsNullOrEmpty(Description))
        {
            <MudText Typo="Typo.caption" Style="color: rgba(230,237,243,0.4);">@Description</MudText>
        }
    </div>
    <MudText Typo="Typo.body1" Style="@($"font-weight:700; color:{Color};")">@Value</MudText>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = default!;
    [Parameter, EditorRequired] public string Value { get; set; } = default!;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string Color { get; set; } = "#E6EDF3";
}
