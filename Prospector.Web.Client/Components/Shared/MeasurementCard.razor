<MudPaper Class="pa-4 text-center" Elevation="0"
          Style="background: #1C2128; border: 1px solid rgba(230,237,243,0.08); border-radius:10px;">
    <MudIcon Icon="@Icon" Style="color: rgba(230,237,243,0.4); margin-bottom:6px;" />
    <MudText Typo="Typo.h6" Style="font-weight:700;">@Value</MudText>
    <MudText Typo="Typo.caption" Style="color: rgba(230,237,243,0.5);">@Label</MudText>
</MudPaper>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = default!;
    [Parameter, EditorRequired] public string Value { get; set; } = default!;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Straighten;
}
